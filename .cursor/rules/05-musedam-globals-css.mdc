/* Focus Ring */
textarea:focus, textarea:focus-visible,
input:focus, input:focus-visible,
select:focus, select:focus-visible {
  border-color: #3366FF;
  box-shadow: 0 0 0 2px rgba(89,139,255,0.2);
}
.dark textarea:focus,
.dark input:focus,
.dark select:focus {
  box-shadow: 0 0 0 2px rgba(89,139,255,0.3);
}

/* Dropdown/Modal Shadow */
:root { --shadow-dropdown: 0 6px 21px 8px rgba(87,98,114,0.07), 0 0 12px rgba(87,98,114,0.15), 0 4px 10px -4px rgba(46,58,89,0.19); }
.dark { --shadow-dropdown: 0 6px 21px 8px rgba(0,0,0,0.2), 0 0 12px rgba(0,0,0,0.3); }

/* Body styles */
body {
  background-color: var(--background);
  color: var(--foreground);
  font-family: var(--font-family-sans);
  line-height: var(--line-height-body);
}
